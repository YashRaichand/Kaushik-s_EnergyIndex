# ─── App ─────────────────────────────────────────────────────
NODE_ENV=production
APP_NAME="Energy Dignity Index"
APP_URL=https://edi-frontend.onrender.com

# ─── Backend ─────────────────────────────────────────────────
BACKEND_URL=https://edi-backend.onrender.com
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/edi_db
POSTGRES_USER=edi_user
POSTGRES_PASSWORD=edi_secure_password
POSTGRES_DB=edi_db

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://edi-backend.onrender.com/api/v1/auth/google/callback

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email (SendGrid) ────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@kaushikdigital.com

# ─── Anthropic (AI Features) ─────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://edi-backend.onrender.com/api/v1
NEXT_PUBLIC_APP_URL=https://edi-frontend.onrender.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
